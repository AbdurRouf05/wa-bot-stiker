# Konfigurasi Bot WhatsApp (Cloud/Local)

# Port untuk server Express (Koyeb/Render otomatis mengisi ini)
PORT=3000

# Session ID: Diperoleh setelah scan QR pertama kali. 
# Biarkan kosong dulu saat scan pertama kali secara lokal.
SESSION_ID=

# Nomor Owner (Nomor kamu, format: 628xxx)
OWNER=628xxx

# RapidAPI Key (Dipakai untuk: YouTube, Instagram, Remini)
# Daftar di https://rapidapi.com/ lalu ambil API Key kamu
RAPIDAPI_KEY=

# Sticker Metadata (Muncul di info stiker)
STICKER_PACK=Abd Bot
STICKER_AUTHOR=wa.me/628xxx
